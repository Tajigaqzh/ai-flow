{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "moduleResolution": "node10",
    "jsx": "react-jsx",
    "types": ["jest", "node"]
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "../../test/apps/web/src/**/*.test.ts",
    "../../test/apps/web/src/**/*.spec.ts",
    "../../test/apps/web/src/**/*.test.tsx",
    "../../test/apps/web/src/**/*.spec.tsx",
    "../../test/apps/web/src/**/*.test.js",
    "../../test/apps/web/src/**/*.spec.js",
    "../../test/apps/web/src/**/*.test.jsx",
    "../../test/apps/web/src/**/*.spec.jsx",
    "../../test/apps/web/src/**/*.d.ts"
  ]
}
