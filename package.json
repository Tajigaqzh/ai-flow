{
  "name": "ai-flow",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n WEB,API -c cyan,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "nx run web:dev",
    "dev:api": "nx run api:serve",
    "start": "concurrently -n WEB,API -c cyan,green \"pnpm start:web\" \"pnpm start:api\"",
    "start:web": "nx run web:dev",
    "start:api": "nx run api:serve",
    "build": "nx run-many -t build -p web api --parallel=2 --skip-nx-cache && pnpm copy:web-dist",
    "build:web": "nx run web:build --skip-nx-cache && pnpm copy:web-dist",
    "build:api": "nx run api:build",
    "copy:web-dist": "node scripts/copy-web-dist.mjs",
    "check:staged": "node scripts/check-staged-files.mjs",
    "commitlint": "commitlint",
    "test:commitlint": "node test/project/commitlint.config.spec.mjs",
    "test:lint-rules": "node test/project/lint-rules.spec.mjs",
    "test:staged-check": "node test/project/check-staged-files.spec.mjs",
    "test": "nx run-many -t test -p web api --parallel=2",
    "test:web": "nx run web:test",
    "test:api": "nx run api:test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "lint": "nx run-many -t lint -p web api --parallel=2",
    "lint:web": "nx run web:lint",
    "lint:api": "nx run api:lint",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "ahooks": "^3.9.7",
    "antd": "^6.5.0",
    "antd-mobile": "^5.42.3",
    "axios": "^1.18.1",
    "openai": "^6.45.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/nest": "23.0.1",
    "@nx/node": "23.0.1",
    "@nx/rsbuild": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.61.1",
    "@rsbuild/core": "1.1.10",
    "@rsbuild/plugin-less": "^1.1.1",
    "@rsbuild/plugin-react": "1.1.0",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "~0.2.38",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "less": "^4.6.7",
    "nx": "23.0.1",
    "postcss": "^8.5.16",
    "prettier": "~3.6.2",
    "tailwindcss": "^4.3.2",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
